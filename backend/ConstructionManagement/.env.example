# or mirror the same values in appsettings.Development.json for local development.

ConnectionStrings__Default=Server=localhost,1433;Database=ManagerDb;User Id=sa;Password=YourStrong!Passw0rd;Encrypt=False;TrustServerCertificate=True;

Frontend__AllowedOrigins__0=http://localhost:5173

Jwt__Issuer=ConstructionManagementApi
Jwt__Audience=ConstructionManagementApiClient
Jwt__SecretKey=replace_with_a_long_random_secret
Jwt__ExpirationMinutes=120

OpenAI__Enabled=false
OpenAI__ApiKey=
OpenAI__Model=gpt-5-mini

BootstrapAdmin__Enabled=false
BootstrapAdmin__Name=
BootstrapAdmin__Username=
BootstrapAdmin__Email=
BootstrapAdmin__Password=

Sms__Enabled=false
Sms__Provider=Twilio
Sms__AccountSid=
Sms__AuthToken=
Sms__FromNumber=

Email__Enabled=true
Email__Provider=Resend
Email__ApiKey=
Email__Host=
Email__Port=587
Email__UseSsl=true
Email__Username=
Email__Password=
Email__FromAddress=
Email__FromName=Construction Manager
